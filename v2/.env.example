# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# Scraper
GROUP_URL=https://www.facebook.com/groups/CrimeaBeauty
GROUP_ID=1883332381741292
MEMBERS_DOC_ID=26296205566653090
HOVERCARD_DOC_ID=33705242655757750
FACEBOOK_IP=31.13.72.36

# Путь к файлу сессии (создаётся session.py)
SESSION_DATA_PATH=session_data.json

# session.py — путь к Chrome-профилю с авторизацией FB
CHROME_PROFILE_PATH=/home/user/.config/google-chrome/Default
# session.py — секунд ожидания после загрузки страницы участников
SESSION_PAGE_WAIT=5

# Задержки между запросами (секунды)
REQUEST_DELAY_MIN=.5
REQUEST_DELAY_MAX=1.0

# Размер батча (участников за один запрос к GraphQL)
BATCH_SIZE=10

# Включить обогащение через hovercard (parse_hovercard)
ENRICH_ENABLED=true

# Директория для хранения аватарок
AVATARS_DIR=media/avatars

# Прокси для обхода блокировок (requests читает автоматически)
# Hiddify: порт смотреть в настройках (ss -tlnp | grep -E '233[0-9]|108[0-9]|789[0-9]')
HTTPS_PROXY=http://127.0.0.1:12334
HTTP_PROXY=http://127.0.0.1:12334
