# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# PostgreSQL (подключаемся через PgBouncer)
POSTGRES_DB=fb_members
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ES_URL=http://elasticsearch:9200
ES_INDEX=fb_members

# Scraper
GROUP_URL=https://www.facebook.com/groups/CrimeaBeauty
GROUP_ID=1883332381741292

# Прокси для Chrome (если сайт заблокирован в регионе)
# Hiddify: socks5://127.0.0.1:2334 (проверить порт в настройках ss -tlnp | grep -E '233[0-9]|108[0-9]|789[0-9]')
CHROME_PROXY=socks5://127.0.0.1:2334

# Путь к файлу сессии (создаётся session.py на хосте, монтируется в контейнер)
SESSION_DATA_PATH=/app/session_data.json
# Максимальный возраст файла сессии в часах (если старше — требуем перезапуск session.py)
SESSION_MAX_AGE_HOURS=12

# Директория для хранения аватарок участников
AVATARS_DIR=/app/media/avatars

